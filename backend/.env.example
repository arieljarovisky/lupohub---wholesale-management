# ============== BASE DE DATOS (obligatorio en Railway) ==============
# Opción 1: URL completa (Railway suele dar MYSQLURL o DATABASE_URL)
# Descomentá y referenciá la variable del plugin MySQL en Railway.
# MYSQL_URL=mysql://user:password@host:3306/railway
# DATABASE_URL=mysql://user:password@host:3306/railway

# Opción 2: Variables sueltas (si Railway no da URL)
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=railway
# DB_PORT=3306

# ============== SERVIDOR ==============
# PORT lo asigna Railway automáticamente; opcional en local
# PORT=3010

# ============== AUTH (recomendado en producción) ==============
# JWT_SECRET=genera-un-secreto-largo-y-aleatorio
# Usuario admin: en producción definí ambos para que se cree al arrancar.
# ADMIN_EMAIL=admin@tudominio.com
# ADMIN_PASSWORD=tu-contraseña-segura

# ============== INTEGRACIONES (opcional; para ML y TN) ==============
# MERCADO_LIBRE_APP_ID=
# MERCADO_LIBRE_CLIENT_SECRET=
# MERCADO_LIBRE_REDIRECT_URI=https://tu-dominio.railway.app/api/integrations/mercadolibre/callback
# TIENDA_NUBE_APP_ID=
# TIENDA_NUBE_CLIENT_SECRET=
# TIENDA_NUBE_REDIRECT_URI=https://tu-backend.railway.app/api/integrations/tiendanube/callback
# TIENDA_NUBE_USER_AGENT=LupoHub (support@lupo.ar)
# Después de conectar ML o Tienda Nube, el backend redirige al frontend. En producción definí la URL del front (Vercel).
# FRONTEND_URL=https://lupohub-wholesale-management.vercel.app
